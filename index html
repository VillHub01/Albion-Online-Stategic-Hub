                `;
                container.appendChild(div);
            });
        }

        function saveGuides() {
            Object.keys(dataStore.guides).forEach(key => {
                dataStore.guides[key].text = document.getElementById(`edit-guide-${key}`).value;
            });
            initGuideView();
            showSuccessMsg('save-guide-msg');
