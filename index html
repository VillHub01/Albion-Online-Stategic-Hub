<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Albion Online Tools</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Custom scrollbar to match dark theme */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #1f2937; }
        ::-webkit-scrollbar-thumb { background: #4b5563; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #6b7280; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .fade-in { animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="bg-gray-900 text-gray-100 font-sans min-h-screen">

    <!-- HEADER -->
    <header class="bg-gray-800 border-b border-gray-700 shadow-md sticky top-0 z-50">
        <div class="container mx-auto px-4 h-16 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <i class="fa-solid fa-shield-halved text-2xl text-amber-500"></i>
                <h1 class="text-xl font-bold tracking-wider text-amber-500 hidden sm:block">ALBION TOOLS</h1>
            </div>
            
            <nav class="flex space-x-2 overflow-x-auto hide-scrollbar">
                <button onclick="switchTab('kalkulator')" id="tab-kalkulator" class="tab-btn px-4 py-2 text-sm font-medium rounded-md transition-colors bg-amber-600 text-white">Kalkulator</button>
                <button onclick="switchTab('build')" id="tab-build" class="tab-btn px-4 py-2 text-sm font-medium rounded-md transition-colors text-gray-300 hover:bg-gray-700">Build</button>
                <button onclick="switchTab('panduan')" id="tab-panduan" class="tab-btn px-4 py-2 text-sm font-medium rounded-md transition-colors text-gray-300 hover:bg-gray-700">Panduan</button>
                <button onclick="switchTab('log')" id="tab-log" class="tab-btn px-4 py-2 text-sm font-medium rounded-md transition-colors text-gray-300 hover:bg-gray-700">Log</button>
            </nav>
            
            <!-- ADMIN LOGO 'A' -->
            <button onclick="switchTab('admin')" class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-700 hover:bg-gray-600 border border-gray-600 transition-colors group" title="Admin Login">
                <span class="text-xl font-bold font-serif text-gray-300 group-hover:text-amber-500">A</span>
            </button>
        </div>
    </header>

    <!-- META UPDATE BOX -->
    <div id="meta-banner" class="bg-amber-900/40 border-l-4 border-amber-500 text-amber-200 p-3 shadow-inner text-sm text-center block">
        <span class="font-bold mr-2"><i class="fa-solid fa-bullhorn"></i> META UPDATE TERBARU:</span> 
        <span id="meta-text-display">Patch 22.1: Bloodletter kena nerf pada cooldown, gunakan dengan lebih hati-hati!</span>
    </div>

    <!-- MAIN CONTENT -->
    <main class="container mx-auto px-4 py-8 max-w-5xl">

        <!-- 1. KALKULATOR VIEW -->
        <section id="view-kalkulator" class="fade-in block">
            <div class="flex gap-4 border-b border-gray-700 pb-2 mb-6">
                <button onclick="switchCalcType('refining')" id="btn-calc-refining" class="flex items-center gap-2 px-4 py-2 rounded-t-lg transition-colors bg-gray-800 text-amber-500 border-b-2 border-amber-500">
                    <i class="fa-solid fa-hammer"></i> Refining / Crafting
                </button>
                <button onclick="switchCalcType('gathering')" id="btn-calc-gathering" class="flex items-center gap-2 px-4 py-2 rounded-t-lg transition-colors text-gray-400 hover:text-gray-200">
                    <i class="fa-solid fa-map"></i> Gathering
                </button>
            </div>

            <!-- Kalkulator Refining -->
            <div id="calc-refining-box" class="bg-gray-800 p-6 rounded-xl shadow-lg border border-gray-700 block">
                <div class="grid md:grid-cols-2 gap-8">
                    <!-- Form Input -->
                    <div class="space-y-4">
                        <h3 class="text-xl font-bold text-gray-200 border-b border-gray-700 pb-2">Input Data Refining</h3>
                        <div>
                            <label class="block text-sm text-gray-400 mb-1">Nama Item Siap Jual</label>
                            <input type="text" id="calc-item" class="w-full bg-gray-900 border border-gray-600 rounded p-2 text-white outline-none focus:border-amber-500" placeholder="Cth: T5 Leather" value="T5 Leather">
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm text-gray-400 mb-1">Total Beli Bahan</label>
                                <input type="number" id="calc-bahan" class="w-full bg-gray-900 border border-gray-600 rounded p-2 text-white outline-none focus:border-amber-500" value="100000">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-400 mb-1">Jumlah Craft / Qty</label>
                                <input type="number" id="calc-qty" class="w-full bg-gray-900 border border-gray-600 rounded p-2 text-white outline-none focus:border-amber-500" value="100">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-400 mb-1">UCV per unit</label>
                                <input type="number" id="calc-ucv" class="w-full bg-gray-900 border border-gray-600 rounded p-2 text-white outline-none focus:border-amber-500" value="50">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-400 mb-1">Harga Jual / unit</label>
                                <input type="number" id="calc-jual" class="w-full bg-gray-900 border border-gray-600 rounded p-2 text-white outline-none focus:border-amber-500" value="1500">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-400 mb-1">Pajak Pasar (%)</label>
                                <input type="number" id="calc-pajak" class="w-full bg-gray-900 border border-gray-600 rounded p-2 text-white outline-none focus:border-amber-500" value="6.5" step="0.1">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-400 mb-1">Return Rate (%)</label>
                                <input type="number" id="calc-return" class="w-full bg-gray-900 border border-gray-600 rounded p-2 text-white outline-none focus:border-amber-500" value="15.2" step="0.1">
                            </div>
                        </div>
                        <button onclick="calculateRefining()" class="w-full bg-amber-600 hover:bg-amber-500 text-white font-bold py-3 rounded mt-4 transition-colors">Hitung Analisa</button>
                    </div>

                    <!-- Hasil Analisa -->
                    <div class="bg-gray-900 p-6 rounded-lg border border-gray-700 relative">
                        <h3 class="text-xl font-bold text-gray-200 border-b border-gray-700 pb-2 mb-4">Hasil Analisa</h3>
                        
                        <div id="calc-result-empty" class="h-full flex items-center justify-center text-gray-500 flex-col gap-2 opacity-50 pb-10 block">
                            <i class="fa-solid fa-calculator text-4xl mb-2"></i>
                            <p>Klik tombol Hitung untuk melihat hasil</p>
                        </div>

                        <div id="calc-result-data" class="space-y-4 hidden">
                            <div class="flex justify-between p-3 bg-gray-800 rounded">
                                <span class="text-gray-400">Total HPP</span> 
                                <span id="res-hpp" class="font-bold text-red-400">0 🪙</span>
                            </div>
                            <div class="flex justify-between p-3 bg-gray-800 rounded">
                                <span class="text-gray-400">Total Jual (Kotor)</span> 
                                <span id="res-kotor" class="font-bold text-blue-400">0 🪙</span>
                            </div>
                            <div class="flex justify-between p-3 bg-gray-800 rounded border border-gray-700">
                                <span class="text-gray-400">Pajak Pasar</span> 
                                <span id="res-pajak" class="font-bold text-gray-500">-0 🪙</span>
                            </div>
                            <div id="res-box-untung" class="flex justify-between p-4 rounded-lg border bg-gray-800">
                                <span class="font-bold text-lg">Keuntungan Bersih</span> 
                                <span id="res-bersih" class="font-bold text-xl">0 🪙</span>
                            </div>
                            <div class="flex justify-between p-3 bg-gray-800 rounded">
                                <span class="text-gray-400">Efisiensi (ROI)</span> 
                                <span id="res-roi" class="font-bold text-amber-500">0%</span>
                            </div>
                            
                            <div class="flex gap-2 pt-4">
                                <button onclick="shareWA()" class="flex-1 flex justify-center items-center gap-2 bg-green-600 hover:bg-green-500 py-2 rounded font-bold transition-colors">
                                    <i class="fa-brands fa-whatsapp"></i> Share WA
                                </button>
                                <button onclick="downloadCSV()" class="flex-1 flex justify-center items-center gap-2 bg-blue-600 hover:bg-blue-500 py-2 rounded font-bold transition-colors">
                                    <i class="fa-solid fa-download"></i> Download
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Kalkulator Gathering -->
            <div id="calc-gathering-box" class="bg-gray-800 p-10 rounded-xl shadow-lg border border-gray-700 text-center hidden">
                <i class="fa-solid fa-pickaxe text-6xl text-gray-600 mb-4"></i>
                <h3 class="text-2xl font-bold text-gray-300">Kalkulator Gathering</h3>
                <p class="text-gray-500 mt-2 max-w-md mx-auto">Logika Gathering memiliki HPP dasar 0 (kecuali konsumsi alat/makanan). Anda dapat menggunakan menu Kalkulator Refining untuk mengolah & menghitung hasil gathering secara mendetail ke depannya.</p>
            </div>
        </section>

        <!-- 2. BUILD VIEW -->
        <section id="view-build" class="fade-in hidden">
            <div class="flex flex-wrap gap-2 mb-6" id="build-categories">
                <!-- Categories injected by JS -->
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                <!-- Gear List -->
                <div class="bg-gray-800 p-6 rounded-xl border border-gray-700">
                    <h3 class="text-xl font-bold text-amber-500 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-shield"></i> Perlengkapan (<span id="active-cat-name">PVP</span>)
                    </h3>
                    <div class="space-y-3" id="gear-slots-container">
                        <!-- Gear slots injected by JS -->
                    </div>
                </div>

                <!-- Reason Box -->
                <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 relative flex flex-col min-h-[400px]">
                    <h3 class="text-xl font-bold text-blue-400 mb-4 flex items-center gap-2 border-b border-gray-700 pb-2">
                        <i class="fa-solid fa-circle-info"></i> Alasan Pemilihan
                    </h3>
                    
                    <div id="reason-empty" class="m-auto text-center text-gray-500 block">
                        <i class="fa-solid fa-hand-pointer text-4xl mb-3 opacity-50"></i>
                        <p>Klik salah satu perlengkapan di sebelah kiri<br/>untuk melihat alasan detailnya.</p>
                    </div>

                    <div id="reason-content" class="fade-in hidden">
                        <h4 id="reason-item-name" class="text-2xl font-black text-white mb-2">Nama Item</h4>
                        <span id="reason-item-slot" class="inline-block px-2 py-1 bg-gray-700 text-xs rounded text-gray-300 mb-4 uppercase">SLOT - KATEGORI</span>
                        
                        <!-- SARAN SKILL BOX -->
                        <div class="mb-4 bg-amber-900/30 border border-amber-600/50 p-4 rounded-lg shadow-inner">
                            <h5 class="text-amber-400 font-bold text-sm mb-2 flex items-center gap-2">
                                <i class="fa-solid fa-wand-magic-sparkles"></i> Saran Skill:
                            </h5>
                            <p id="reason-item-skill" class="text-amber-100 font-mono text-sm font-semibold tracking-wide">
                                Q: Skill 1 | W: Skill 2 | Pasif: Skill 3
                            </p>
                        </div>

                        <p id="reason-item-desc" class="text-gray-300 text-lg leading-relaxed bg-gray-900 p-4 rounded-lg border-l-4 border-blue-500">
                            Alasan...
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- 3. PANDUAN VIEW -->
        <section id="view-panduan" class="fade-in hidden">
            <div class="grid md:grid-cols-2 gap-6" id="guides-container">
                <!-- Guides injected by JS -->
            </div>
        </section>

        <!-- 4. LOG VIEW (Pencatatan Pendapatan) -->
        <section id="view-log" class="fade-in hidden">
            <div class="grid md:grid-cols-3 gap-8">
                
                <!-- Kolom Kiri: Form Input -->
                <div class="bg-gray-800 p-6 rounded-xl shadow-lg border border-gray-700 h-fit">
                    <h3 class="text-xl font-bold text-amber-500 border-b border-gray-700 pb-2 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-book-journal-whills"></i> Catat Pendapatan
                    </h3>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm text-gray-400 mb-1">Jenis Aktivitas</label>
                            <select id="log-activity" class="w-full bg-gray-900 border border-gray-600 rounded p-3 text-white outline-none focus:border-amber-500">
                                <option value="Gathering">Gathering (Kumpul Bahan)</option>
                                <option value="Faction">Faction Warfare</option>
                                <option value="Market">Market (Trading/Refining)</option>
                                <option value="Dungeon">Dungeon / PvE</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm text-gray-400 mb-1">Jumlah Silver</label>
                            <input type="number" id="log-silver" class="w-full bg-gray-900 border border-gray-600 rounded p-3 text-white outline-none focus:border-amber-500" placeholder="Cth: 1500000">
                            <span id="log-error-msg" class="text-red-400 text-xs mt-1 font-semibold hidden"><i class="fa-solid fa-circle-exclamation"></i> Masukkan jumlah silver yang valid (lebih dari 0).</span>
                        </div>
                        <button onclick="addLog()" class="w-full bg-amber-600 hover:bg-amber-500 text-white font-bold py-3 rounded transition-colors mt-2">
                            Simpan Log Harian
                        </button>
                    </div>
                </div>

                <!-- Kolom Kanan: Tabel Riwayat -->
                <div class="md:col-span-2 bg-gray-800 p-6 rounded-xl shadow-lg border border-gray-700">
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-gray-700 pb-3 mb-4 gap-4">
                        <h3 class="text-xl font-bold text-blue-400 flex items-center gap-2">
                            <i class="fa-solid fa-list-check"></i> Riwayat Pencatatan
                        </h3>
                        <div class="bg-gray-900 px-4 py-2 rounded-lg border border-gray-600 flex items-center gap-2">
                            <span class="text-sm text-gray-400 uppercase tracking-wider font-bold">Total Akumulasi:</span>
                            <span id="log-total-silver" class="font-bold text-xl text-amber-400">0 🪙</span>
                        </div>
                    </div>
                    
                    <div class="overflow-x-auto rounded-lg border border-gray-700">
                        <table class="w-full text-left border-collapse whitespace-nowrap">
                            <thead>
                                <tr class="bg-gray-900 text-gray-400 text-sm border-b border-gray-700">
                                    <th class="p-4 font-semibold">Tanggal</th>
                                    <th class="p-4 font-semibold">Aktivitas</th>
                                    <th class="p-4 font-semibold text-right">Jumlah (Silver)</th>
                                </tr>
                            </thead>
                            <tbody id="log-table-body" class="bg-gray-800">
                                <!-- Data logs injected via JS -->
                                <tr>
                                    <td colspan="3" class="p-8 text-center text-gray-500">
                                        <i class="fa-solid fa-box-open text-3xl mb-2"></i><br>
                                        Belum ada data pendapatan yang dicatat.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </section>

        <!-- 5. ADMIN DASHBOARD -->
        <section id="view-admin" class="fade-in hidden">
            
            <!-- Login Form -->
            <div id="admin-login" class="max-w-md mx-auto mt-10 bg-gray-800 p-8 rounded-xl shadow-2xl border border-gray-700 block">
                <div class="flex justify-center mb-6">
                    <div class="w-16 h-16 bg-gray-900 rounded-full flex items-center justify-center border-2 border-amber-500">
                        <span class="text-3xl font-bold font-serif text-amber-500">A</span>
                    </div>
                </div>
                <h2 class="text-2xl font-bold text-center text-white mb-6">Portal Admin Rahasia</h2>
                <div class="space-y-4">
                    <div>
                        <label class="block text-gray-400 mb-2 text-sm">Password Akses</label>
                        <input type="password" id="admin-pwd" class="w-full bg-gray-900 border border-gray-600 rounded p-3 text-white focus:border-amber-500 outline-none" placeholder="Masukkan password...">
                    </div>
                    <p id="admin-error" class="text-red-400 text-sm font-bold hidden">Password salah! (Hint: admin123)</p>
                    <button onclick="loginAdmin()" class="w-full bg-amber-600 hover:bg-amber-500 text-white font-bold py-3 rounded flex justify-center items-center gap-2 transition-colors">
                        <i class="fa-solid fa-right-to-bracket"></i> Masuk Dashboard
                    </button>
                </div>
            </div>

            <!-- Dashboard Content -->
            <div id="admin-dashboard" class="space-y-8 hidden">
                <div class="flex justify-between items-end border-b border-gray-700 pb-4">
                    <div>
                        <h2 class="text-3xl font-black text-amber-500 flex items-center gap-3"><i class="fa-solid fa-gear"></i> Admin Dashboard</h2>
                        <p class="text-gray-400 mt-1">Ubah data web secara langsung.</p>
                    </div>
                    <button onclick="logoutAdmin()" class="px-4 py-2 bg-gray-700 hover:bg-red-900 text-white rounded text-sm transition-colors">Logout</button>
                </div>

                <!-- 1. Meta Update -->
                <div class="bg-gray-800 p-6 rounded-xl border border-gray-700">
                    <h3 class="text-xl font-bold text-white mb-4">Pengontrol Pengumuman (Patch Notes Updater)</h3>
                    <textarea id="edit-meta" class="w-full bg-gray-900 border border-gray-600 rounded p-3 text-white mb-3" rows="2"></textarea>
                    <div class="flex justify-end items-center gap-4">
                        <span id="save-meta-msg" class="text-green-400 text-sm font-bold opacity-0 transition-opacity"><i class="fa-solid fa-check"></i> Tersimpan!</span>
                        <button onclick="saveMeta()" class="px-4 py-2 bg-amber-600 hover:bg-amber-500 rounded text-white font-bold">Simpan Meta</button>
                    </div>
                </div>

                <!-- 2. Manajemen Build -->
                <div class="bg-gray-800 p-6 rounded-xl border border-gray-700">
                    <h3 class="text-xl font-bold text-white mb-4">Manajemen Build (Build Manager)</h3>
                    <div class="flex flex-col md:flex-row gap-6">
                        <div class="md:w-1/3 space-y-4">
                            <div>
                                <label class="block text-gray-400 text-sm mb-1">Pilih Kategori</label>
                                <select id="edit-build-cat" onchange="loadBuildEditor()" class="w-full bg-gray-900 border border-gray-600 rounded p-2 text-white outline-none focus:border-amber-500"></select>
                            </div>
                            <div>
                                <label class="block text-gray-400 text-sm mb-1">Pilih Slot Perlengkapan</label>
                                <select id="edit-build-slot" onchange="loadBuildEditor()" class="w-full bg-gray-900 border border-gray-600 rounded p-2 text-white outline-none focus:border-amber-500">
                                    <option value="Kepala">Kepala</option>
                                    <option value="Dada">Dada</option>
                                    <option value="Kaki">Kaki</option>
                                    <option value="Senjata Jarak Dekat">Senjata Jarak Dekat</option>
                                    <option value="Senjata Jarak Jauh">Senjata Jarak Jauh</option>
                                    <option value="Jubah">Jubah</option>
                                </select>
                            </div>
                        </div>
                        <div class="md:w-2/3 bg-gray-900 p-4 rounded border border-gray-600 space-y-4">
                            <h4 class="font-bold text-amber-500 border-b border-gray-700 pb-2"><i class="fa-solid fa-pen"></i> Form Edit Item</h4>
                            <div>
                                <label class="block text-gray-400 text-sm mb-1">Nama Item</label>
                                <input type="text" id="edit-build-name" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white">
                            </div>
                            <div>
                                <label class="block text-gray-400 text-sm mb-1">Saran Skill <span class="text-xs text-gray-500">(Q, W, E, Pasif)</span></label>
                                <input type="text" id="edit-build-skill" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-amber-200 font-mono text-sm" placeholder="Contoh: Q: Cleave | W: Dash | Pasif: Deep Cuts">
                            </div>
                            <div>
                                <label class="block text-gray-400 text-sm mb-1">Alasan Penggunaan</label>
                                <textarea id="edit-build-reason" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white" rows="3"></textarea>
                            </div>
                            <div class="flex justify-end items-center gap-4">
                                <span id="save-build-msg" class="text-green-400 text-sm font-bold opacity-0 transition-opacity"><i class="fa-solid fa-check"></i> Tersimpan!</span>
                                <button onclick="saveBuild()" class="px-4 py-2 bg-amber-600 hover:bg-amber-500 rounded text-white font-bold">Update Build</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 3. Manajemen Guides -->
                <div class="bg-gray-800 p-6 rounded-xl border border-gray-700">
                    <h3 class="text-xl font-bold text-white mb-4">Manajemen Konten Strategi</h3>
                    <div class="grid md:grid-cols-2 gap-4" id="admin-guides-container">
                        <!-- Admin guides injected by JS -->
                    </div>
                    <div class="flex justify-end items-center gap-4 mt-4">
                        <span id="save-guide-msg" class="text-green-400 text-sm font-bold opacity-0 transition-opacity"><i class="fa-solid fa-check"></i> Tersimpan!</span>
                        <button onclick="saveGuides()" class="px-4 py-2 bg-amber-600 hover:bg-amber-500 rounded text-white font-bold">Simpan Panduan</button>
                    </div>
                </div>

            </div>
        </section>

    </main>

    <!-- JAVASCRIPT LOGIC -->
    <script>
        /* =======================================
           DATA STATE (Mocking Database)
        ======================================= */
        let dataStore = {
            meta: "Patch 22.1: Bloodletter kena nerf pada cooldown, gunakan dengan lebih hati-hati!",
            logs: [
                // Contoh data log awal (opsional, dapat dihapus agar mulai dari kosong)
                { date: "19-06-2026", activity: "Gathering", silver: 450000 },
                { date: "20-06-2026", activity: "Dungeon", silver: 210000 }
            ],
            builds: {
                PVP: {
                    Kepala: { nama: "Mage Cowl", skill: "Skill 3: Poison | Pasif: Aggression", alasan: "Memberikan efek poison tambahan untuk burst damage saat ganking." },
                    Dada: { nama: "Cleric Robe", skill: "Skill 3: Everlasting Spirit | Pasif: Aggression", alasan: "Skill invincibility (Everlasting Spirit) sangat krusial untuk bertahan hidup dari counter-attack." },
