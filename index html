        /* =======================================
           LOGIC: LOG HARIAN PENDAPATAN
        ======================================= */
        function addLog() {
            let activity = document.getElementById('log-activity').value;
            let silverInput = document.getElementById('log-silver').value;
            let silverAmount = parseInt(silverInput);
            let errorMsg = document.getElementById('log-error-msg');

            // Validasi Input
            if (isNaN(silverAmount) || silverAmount <= 0) {
                errorMsg.classList.remove('hidden');
                return;
            }
            errorMsg.classList.add('hidden');

            // Pembuatan Tanggal Otomatis (Format: DD-MM-YYYY)
            let today = new Date();
            let dd = String(today.getDate()).padStart(2, '0');
            let mm = String(today.getMonth() + 1).padStart(2, '0'); // Januari adalah 0
            let yyyy = today.getFullYear();
            let dateStr = dd + '-' + mm + '-' + yyyy;

            // Memasukkan ke dalam array dataStore
            dataStore.logs.push({
                date: dateStr,
                activity: activity,
                silver: silverAmount
            });

            // Kosongkan form input
            document.getElementById('log-silver').value = '';

            // Update Tabel
            renderLogs();
        }

        function renderLogs() {
            let tbody = document.getElementById('log-table-body');
            let totalEl = document.getElementById('log-total-silver');
            
            tbody.innerHTML = '';
            
            // Jika data kosong
            if (dataStore.logs.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="3" class="p-8 text-center text-gray-500">
                            <i class="fa-solid fa-box-open text-3xl mb-2"></i><br>
                            Belum ada data pendapatan yang dicatat.
                        </td>
                    </tr>
                `;
                totalEl.innerText = "0 🪙";
                return;
            }

            // Loop dan Render Data secara terbalik (Terbaru di atas)
            for (let i = dataStore.logs.length - 1; i >= 0; i--) {
                let log = dataStore.logs[i];
                let tr = document.createElement('tr');
                tr.className = "border-b border-gray-700/50 hover:bg-gray-700/50 transition-colors";
                
                // Menentukan warna icon berdasarkan tipe
                let iconStr = '<i class="fa-solid fa-coins text-gray-400 mr-2"></i>';
                if(log.activity.includes('Gathering')) iconStr = '<i class="fa-solid fa-pickaxe text-amber-500 mr-2"></i>';
                if(log.activity.includes('Faction')) iconStr = '<i class="fa-solid fa-flag text-red-500 mr-2"></i>';
                if(log.activity.includes('Market')) iconStr = '<i class="fa-solid fa-shop text-blue-400 mr-2"></i>';
                if(log.activity.includes('Dungeon')) iconStr = '<i class="fa-solid fa-dungeon text-purple-400 mr-2"></i>';

                tr.innerHTML = `
                    <td class="p-4 text-sm text-gray-300 whitespace-nowrap">${log.date}</td>
                    <td class="p-4 text-sm text-gray-200 font-medium">${iconStr} ${log.activity}</td>
                    <td class="p-4 text-right text-sm font-bold text-green-400">+${log.silver.toLocaleString('id-ID')}</td>
                `;
                tbody.appendChild(tr);
            }

            // Hitung Total Akumulasi Silver
            let total = dataStore.logs.reduce((sum, item) => sum + item.silver, 0);
            totalEl.innerText = total.toLocaleString('id-ID') + " 🪙";
        }

        /* =======================================
           KALKULATOR LOGIC
        ======================================= */
        function switchCalcType(type) {
            if(type === 'refining') {
                document.getElementById('calc-refining-box').classList.remove('hidden');
                document.getElementById('calc-gathering-box').classList.add('hidden');
                document.getElementById('btn-calc-refining').className = "flex items-center gap-2 px-4 py-2 rounded-t-lg transition-colors bg-gray-800 text-amber-500 border-b-2 border-amber-500";
                document.getElementById('btn-calc-gathering').className = "flex items-center gap-2 px-4 py-2 rounded-t-lg transition-colors text-gray-400 hover:text-gray-200";
            } else {
                document.getElementById('calc-refining-box').classList.add('hidden');
                document.getElementById('calc-gathering-box').classList.remove('hidden');
                document.getElementById('btn-calc-gathering').className = "flex items-center gap-2 px-4 py-2 rounded-t-lg transition-colors bg-gray-800 text-amber-500 border-b-2 border-amber-500";
                document.getElementById('btn-calc-refining').className = "flex items-center gap-2 px-4 py-2 rounded-t-lg transition-colors text-gray-400 hover:text-gray-200";
            }
        }

        function calculateRefining() {
            let item = document.getElementById('calc-item').value || 'Item';
            let bahan = parseFloat(document.getElementById('calc-bahan').value) || 0;
            let qty = parseFloat(document.getElementById('calc-qty').value) || 1;
            let ucv = parseFloat(document.getElementById('calc-ucv').value) || 0;
            let jual = parseFloat(document.getElementById('calc-jual').value) || 0;
            let pajak = parseFloat(document.getElementById('calc-pajak').value) || 0;
            let returnRate = parseFloat(document.getElementById('calc-return').value) || 0;

            let biayaProses = ucv * qty;
            let totalHPP = bahan + biayaProses;
            let extraQty = (returnRate / 100) * qty;
            let totalOutput = qty + extraQty;

            let totalKotor = jual * totalOutput;
            let pajakNominal = totalKotor * (pajak / 100);
            let untungBersih = totalKotor - totalHPP - pajakNominal;
            let roi = totalHPP > 0 ? (untungBersih / totalHPP) * 100 : 0;

            lastCalcResult = { item, totalHPP, totalKotor, pajakNominal, untungBersih, roi };

            document.getElementById('calc-result-empty').classList.add('hidden');
            document.getElementById('calc-result-data').classList.remove('hidden');

            document.getElementById('res-hpp').innerText = formatNum(totalHPP) + " 🪙";
            document.getElementById('res-kotor').innerText = formatNum(totalKotor) + " 🪙";
            document.getElementById('res-pajak').innerText = "-" + formatNum(pajakNominal) + " 🪙";
            
            let resBersihEl = document.getElementById('res-bersih');
            let resBoxUntung = document.getElementById('res-box-untung');
            resBersihEl.innerText = (untungBersih > 0 ? '+' : '') + formatNum(untungBersih) + " 🪙";
            
            if(untungBersih >= 0) {
                resBersihEl.className = "font-bold text-xl text-green-400";
                resBoxUntung.className = "flex justify-between p-4 rounded-lg border bg-green-900/30 border-green-700";
            } else {
                resBersihEl.className = "font-bold text-xl text-red-400";
                resBoxUntung.className = "flex justify-between p-4 rounded-lg border bg-red-900/30 border-red-700";
            }

            document.getElementById('res-roi').innerText = roi.toFixed(2) + "%";
        }

        function formatNum(num) { return num.toLocaleString('id-ID', { maximumFractionDigits: 0 }); }

        function shareWA() {
            if(!lastCalcResult) return;
            let r = lastCalcResult;
            let text = `📊 Hasil Analisa ${r.item}\nHPP: ${formatNum(r.totalHPP)}\nJual Kotor: ${formatNum(r.totalKotor)}\nUntung Bersih: ${formatNum(r.untungBersih)}\nEfisiensi (ROI): ${r.roi.toFixed(2)}%`;
            window.open(`https://wa.me/?text=${encodeURIComponent(text)}`);
        }

        function downloadCSV() {
            if(!lastCalcResult) return;
            let r = lastCalcResult;
            let csvContent = `Item,Total HPP,Total Jual Kotor,Pajak,Keuntungan Bersih,ROI(%)\n"${r.item}",${r.totalHPP},${r.totalKotor},${r.pajakNominal},${r.untungBersih},${r.roi.toFixed(2)}`;
            let blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            let link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.download = `AlbionCalc_${r.item}.csv`;
            link.click();
        }

        /* =======================================
           BUILD LOGIC 
        ======================================= */
        function initBuildView() {
            let catContainer = document.getElementById('build-categories');
            catContainer.innerHTML = '';
            Object.keys(dataStore.builds).forEach(cat => {
                let btn = document.createElement('button');
                let displayCat = cat.replace('_', ' ');
                btn.innerText = displayCat;
                btn.onclick = () => selectBuildCat(cat);
                if(cat === currentActiveBuildCat) {
                    btn.className = "px-5 py-3 rounded-lg font-bold transition-all bg-amber-600 text-white shadow-lg scale-105";
                } else {
                    btn.className = "px-5 py-3 rounded-lg font-bold transition-all bg-gray-800 text-gray-400 hover:bg-gray-700";
                }
                btn.id = "btn-cat-" + cat;
                catContainer.appendChild(btn);
            });
            renderGearSlots();
        }

        function selectBuildCat(cat) {
            currentActiveBuildCat = cat;
            currentActiveGearSlot = null;
            initBuildView();
            document.getElementById('active-cat-name').innerText = cat.replace('_', ' ');
            document.getElementById('reason-empty').classList.remove('hidden');
            document.getElementById('reason-content').classList.add('hidden');
        }

        function renderGearSlots() {
            let container = document.getElementById('gear-slots-container');
            container.innerHTML = '';
            let slots = ['Kepala', 'Dada', 'Kaki', 'Senjata Jarak Dekat', 'Senjata Jarak Jauh', 'Jubah'];
            let currentBuild = dataStore.builds[currentActiveBuildCat];

            slots.forEach(slot => {
                let div = document.createElement('div');
                let isSelected = slot === currentActiveGearSlot;
                
                div.className = `p-4 border rounded-lg cursor-pointer transition-all flex justify-between items-center group ${isSelected ? 'bg-amber-900/30 border-amber-500' : 'bg-gray-900 border-gray-700 hover:border-gray-500'}`;
                div.onclick = () => selectGearSlot(slot);

                let iconStr = "";
                if(slot === 'Senjata Jarak Dekat') iconStr = '<i class="fa-solid fa-sword mr-1"></i>';
                if(slot === 'Senjata Jarak Jauh') iconStr = '<i class="fa-solid fa-bow-arrow mr-1"></i>';

                div.innerHTML = `
                    <div class="flex flex-col">
                        <span class="text-xs text-gray-500 uppercase font-bold tracking-wider">${iconStr}${slot}</span>
                        <span class="font-bold text-lg ${isSelected ? 'text-amber-400' : 'text-gray-200 group-hover:text-amber-400'} transition-colors">
                            ${currentBuild[slot].nama}
                        </span>
                    </div>
                    <div class="w-3 h-3 rounded-full ${isSelected ? 'bg-amber-500' : 'bg-gray-700'}"></div>
                `;
                container.appendChild(div);
            });
        }

        function selectGearSlot(slot) {
            currentActiveGearSlot = slot;
            renderGearSlots();

            let gearData = dataStore.builds[currentActiveBuildCat][slot];
            
            document.getElementById('reason-empty').classList.add('hidden');
            document.getElementById('reason-content').classList.remove('hidden');
            
            document.getElementById('reason-item-name').innerText = gearData.nama;
            document.getElementById('reason-item-slot').innerText = `${slot} - ${currentActiveBuildCat.replace('_', ' ')}`;
            
            document.getElementById('reason-item-skill').innerText = gearData.skill || 'Tidak ada rekomendasi skill khusus.';
            document.getElementById('reason-item-desc').innerText = gearData.alasan;
        }

