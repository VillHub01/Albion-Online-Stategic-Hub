        function loadBuildEditor() {
            let cat = document.getElementById('edit-build-cat').value;
            let slot = document.getElementById('edit-build-slot').value;
            let data = dataStore.builds[cat][slot];
            
            document.getElementById('edit-build-name').value = data.nama;
            document.getElementById('edit-build-skill').value = data.skill || ''; 
            document.getElementById('edit-build-reason').value = data.alasan;
        }

        function saveBuild() {
            let cat = document.getElementById('edit-build-cat').value;
            let slot = document.getElementById('edit-build-slot').value;
            let name = document.getElementById('edit-build-name').value;
            let skill = document.getElementById('edit-build-skill').value;
            let reason = document.getElementById('edit-build-reason').value;

            dataStore.builds[cat][slot] = { nama: name, skill: skill, alasan: reason };
            
            initBuildView();
            if(currentActiveGearSlot) selectGearSlot(currentActiveGearSlot);
            
            showSuccessMsg('save-build-msg');
        }

        function loadAdminGuides() {
            let container = document.getElementById('admin-guides-container');
            container.innerHTML = '';
            Object.keys(dataStore.guides).forEach(key => {
                let val = dataStore.guides[key];
                let div = document.createElement('div');
